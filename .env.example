# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용 (클라이언트 노출 금지, GitHub Actions/관리 스크립트에서만 사용)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (태그 선택) ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── 보안 시크릿 ──────────────────────────────────────────
# Push 알림 발송 API 인증 (GitHub Actions → /api/notifications/send)
CRON_SECRET=random-long-secret
# ISR 캐시 갱신 API 인증 (GitHub Actions → /api/revalidate)
REVALIDATE_SECRET=random-long-secret

# ── 사이트 ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://devblog.kr

# ── Web Push (VAPID) ─────────────────────────────────────
# 생성: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# ── Analytics (선택) ─────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
